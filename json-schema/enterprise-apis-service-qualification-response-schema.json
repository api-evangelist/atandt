{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devex-web.att.com/schemas/enterprise/service-qualification-response",
  "title": "Service Qualification Response",
  "description": "Results of AT&T wireline service qualification check",
  "type": "object",
  "properties": {
    "qualificationId": {
      "type": "string"
    },
    "qualificationDate": {
      "type": "string",
      "format": "date"
    },
    "serviceQualificationItems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "done",
              "terminatedWithError"
            ]
          },
          "serviceSpecification": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          },
          "eligibilityUnavailabilityReason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}